---
import BaseLayout from '@layouts/BaseLayout.astro';
import BlogPostCard from '@components/BlogPostCard.astro';
import { getCollection } from 'astro:content';
import { getReadingTime } from '@utils/readingTime';

const PAGE_SIZE = 12;

const allPosts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const posts = allPosts.slice(0, PAGE_SIZE);
const [featuredPost, ...remainingPosts] = posts;
const totalPages = Math.ceil(allPosts.length / PAGE_SIZE);
const hasNextPage = allPosts.length > PAGE_SIZE;
---

<BaseLayout
  title="Blog"
  description="Articles about building with AI, vibe coding, and creating tools without an engineering background."
>
  <!-- Page Header -->
  <section class="py-12 sm:py-16">
    <div class="animate-in">
      <h1
        class="text-4xl sm:text-5xl font-bold text-neutral-900 mb-6 tracking-tight"
      >
        Blog
      </h1>
      <p class="text-xl text-neutral-600 max-w-2xl leading-relaxed">
        Practical guides and lessons on building with AI — no engineering degree required.
      </p>
    </div>
  </section>

  <!-- Blog Posts -->
  <section class="py-8 border-t border-neutral-200">
    {
      posts.length === 0 ? (
        <div class="text-center py-12 animate-in delay-2">
          <p class="text-neutral-500 mb-4">No posts yet. Check back soon!</p>
          <a href="/" class="text-primary-600 hover:text-primary-700 font-medium">
            ← Back to home
          </a>
        </div>
      ) : (
        <div class="animate-in delay-2">
          {/* Featured post */}
          {featuredPost && (
            <div class="mb-12">
              <BlogPostCard
                title={featuredPost.data.title}
                description={featuredPost.data.description}
                href={`/blog/${featuredPost.id}`}
                pubDate={featuredPost.data.pubDate}
                readingTime={getReadingTime(featuredPost.body || '')}
                heroImage={featuredPost.data.heroImage}
                featured={true}
              />
            </div>
          )}

          {/* Remaining posts grid */}
          {remainingPosts.length > 0 && (
            <div class="grid sm:grid-cols-2 gap-8">
              {remainingPosts.map((post) => (
                <BlogPostCard
                  title={post.data.title}
                  description={post.data.description}
                  href={`/blog/${post.id}`}
                  pubDate={post.data.pubDate}
                  readingTime={getReadingTime(post.body || '')}
                  heroImage={post.data.heroImage}
                />
              ))}
            </div>
          )}
        </div>
      )
    }
  </section>

  <!-- Pagination -->
  {hasNextPage && (
    <nav class="py-10 border-t border-neutral-200 animate-in delay-3">
      <div class="flex items-center justify-between">
        <span class="btn btn-secondary opacity-40 pointer-events-none">
          ← Newer Posts
        </span>
        <span class="text-sm text-neutral-500">
          Page 1 of {totalPages}
        </span>
        <a href="/blog/2" class="btn btn-secondary">
          Older Posts →
        </a>
      </div>
    </nav>
  )}

  <!-- Newsletter CTA -->
  <section class="py-12 border-t border-neutral-200">
    <div class="animate-in delay-3">
      <div class="card p-8 text-center">
        <h2 class="text-xl font-semibold text-neutral-900 mb-2">
          Stay Updated
        </h2>
        <p class="text-neutral-600 mb-4 max-w-md mx-auto">
          New posts on building with AI, vibe coding, and shipping without an engineering team.
        </p>
        <div class="flex flex-wrap justify-center gap-3">
          <a href="/rss.xml" class="btn btn-secondary">
            <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 24 24">
              <path
                d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19 7.38 20 6.18 20C5 20 4 19 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1Z"
              ></path>
            </svg>
            RSS Feed
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
