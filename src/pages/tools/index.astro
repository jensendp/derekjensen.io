---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout
  title="Free AI Prompt Builder"
  description="Describe your idea, answer 3 questions, get a project brief and ready-to-paste Claude prompts in under 60 seconds. Free from Derek Jensen."
>
  <!-- Hero -->
  <section class="py-16 sm:py-24 animate-in">
    <div class="max-w-2xl">
      <p class="text-sm font-semibold uppercase tracking-wider text-primary-600 mb-4">Free Tool</p>
      <h1 class="text-4xl sm:text-5xl font-bold text-neutral-900 tracking-tight mb-6">
        Your AI project brief and prompts — in 60 seconds.
      </h1>
      <p class="text-xl text-neutral-600 leading-relaxed mb-10">
        Describe your idea. Answer 3 quick questions. Get a project brief, a kickoff prompt, and a planning prompt — all ready to paste directly into Claude.
      </p>

      <!-- Opt-in form -->
      <div class="bg-white rounded-xl border border-neutral-200 shadow-sm p-6 sm:p-8">
        <h2 class="text-lg font-semibold text-neutral-900 mb-1">Get free access</h2>
        <p class="text-sm text-neutral-500 mb-5">Enter your email and we'll send you the link instantly.</p>

        <form id="optin-form" class="space-y-3">
          <div class="flex flex-col sm:flex-row gap-3">
            <input
              type="text"
              name="firstName"
              placeholder="First name (optional)"
              class="sm:w-36 rounded-lg border border-neutral-300 bg-white px-4 py-2.5 text-sm text-neutral-900 placeholder-neutral-400 focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-200"
            />
            <input
              type="email"
              name="email"
              placeholder="your@email.com"
              required
              class="flex-1 rounded-lg border border-neutral-300 bg-white px-4 py-2.5 text-sm text-neutral-900 placeholder-neutral-400 focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-200"
            />
          </div>
          <button type="submit" id="optin-btn" class="btn-primary w-full sm:w-auto">
            Send Me the Link →
          </button>
        </form>

        <div id="optin-success" class="hidden">
          <div class="flex items-start gap-3 mt-2">
            <span class="text-2xl">✅</span>
            <div>
              <p class="font-semibold text-neutral-900">Check your inbox.</p>
              <p class="text-sm text-neutral-500">The link to the prompt builder is on its way.</p>
            </div>
          </div>
        </div>

        <p id="optin-error" class="hidden mt-3 text-sm text-red-600"></p>
        <p class="mt-4 text-xs text-neutral-400">Free. No spam. Unsubscribe anytime.</p>
      </div>
    </div>
  </section>

  <!-- What you get -->
  <section class="py-12 border-t border-neutral-100 animate-in delay-1">
    <h2 class="text-sm font-semibold uppercase tracking-wider text-neutral-500 mb-8">What you get</h2>
    <div class="grid sm:grid-cols-3 gap-6">
      <div class="card p-6">
        <div class="text-2xl mb-3">📋</div>
        <h3 class="font-semibold text-neutral-900 mb-2">Project Brief</h3>
        <p class="text-sm text-neutral-600">A crisp one-page summary of the problem, solution, target user, and what success looks like. Clarity before you build anything.</p>
      </div>
      <div class="card p-6">
        <div class="text-2xl mb-3">⚡</div>
        <h3 class="font-semibold text-neutral-900 mb-2">Kickoff Prompt</h3>
        <p class="text-sm text-neutral-600">A ready-to-paste prompt that gives Claude everything it needs to start building with you. No more staring at a blank chat.</p>
      </div>
      <div class="card p-6">
        <div class="text-2xl mb-3">🗺️</div>
        <h3 class="font-semibold text-neutral-900 mb-2">Planning Prompt</h3>
        <p class="text-sm text-neutral-600">A prompt that breaks your project into 5–7 concrete steps, with the right AI tool for each phase. A roadmap, not a wall of text.</p>
      </div>
    </div>
  </section>

  <!-- Who it's for -->
  <section class="py-12 border-t border-neutral-100 animate-in delay-2">
    <div class="max-w-xl">
      <h2 class="text-sm font-semibold uppercase tracking-wider text-neutral-500 mb-4">Who it's for</h2>
      <p class="text-neutral-600 leading-relaxed">
        Built for anyone who has an idea and doesn't know how to talk to AI tools effectively — entrepreneurs, founders, and professionals who want to build real things without writing code.
      </p>
      <p class="text-neutral-600 leading-relaxed mt-3">
        If you've ever opened Claude and typed something vague and gotten something useless back, this fixes that.
      </p>
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.getElementById('optin-form') as HTMLFormElement;
  const btn = document.getElementById('optin-btn') as HTMLButtonElement;
  const success = document.getElementById('optin-success') as HTMLElement;
  const error = document.getElementById('optin-error') as HTMLElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = (form.elements.namedItem('email') as HTMLInputElement).value;
    const firstName = (form.elements.namedItem('firstName') as HTMLInputElement).value;

    btn.disabled = true;
    btn.textContent = 'Sending...';
    error.classList.add('hidden');

    try {
      const res = await fetch('/api/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, firstName }),
      });

      if (res.ok) {
        form.classList.add('hidden');
        success.classList.remove('hidden');
      } else {
        const data = await res.json();
        error.textContent = data.error || 'Something went wrong. Please try again.';
        error.classList.remove('hidden');
        btn.disabled = false;
        btn.textContent = 'Send Me the Link →';
      }
    } catch {
      error.textContent = 'Something went wrong. Please try again.';
      error.classList.remove('hidden');
      btn.disabled = false;
      btn.textContent = 'Send Me the Link →';
    }
  });
</script>
