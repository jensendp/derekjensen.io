---
import BaseLayout from '@layouts/BaseLayout.astro';
import ContactCTA from '@components/ContactCTA.astro';
import { getEntry } from 'astro:content';

const project = await getEntry('projects', 'curb-appeal');
const { title, description, problem, solution, technologies } = project.data;
---

<BaseLayout
  title={title}
  description={description}
>
  <section class="py-12 sm:py-16">
    <div class="animate-in">
      <p class="text-sm font-medium text-accent-600 uppercase tracking-wider mb-3">Project</p>
      <h1 class="text-4xl sm:text-5xl font-bold text-neutral-900 mb-6 tracking-tight">
        {title}
      </h1>
      <p class="text-xl text-neutral-600 max-w-2xl leading-relaxed">
        {description}
      </p>
    </div>
  </section>

  <section class="py-12 border-t border-neutral-200">
    <div class="animate-in delay-1 grid md:grid-cols-2 gap-12">
      <div>
        <h2 class="text-sm font-medium text-neutral-500 uppercase tracking-wider mb-4">The Problem</h2>
        <p class="text-neutral-700 leading-relaxed">{problem}</p>
      </div>
      <div>
        <h2 class="text-sm font-medium text-neutral-500 uppercase tracking-wider mb-4">The Solution</h2>
        <p class="text-neutral-700 leading-relaxed">{solution}</p>
      </div>
    </div>
  </section>

  <section class="py-12 border-t border-neutral-200">
    <div class="animate-in delay-2">
      <h2 class="text-sm font-medium text-neutral-500 uppercase tracking-wider mb-4">Built With</h2>
      <div class="flex flex-wrap gap-2">
        {technologies.map((tech) => (
          <span class="px-3 py-1 text-sm font-medium bg-neutral-100 text-neutral-700 rounded-full">
            {tech}
          </span>
        ))}
      </div>
    </div>
  </section>

  <section class="py-12 border-t border-neutral-200">
    <div class="animate-in delay-3">
      <h2 class="text-sm font-medium text-neutral-500 uppercase tracking-wider mb-4">How It Works</h2>
      <div class="prose max-w-none text-neutral-700 leading-relaxed space-y-4">
        <p>More details coming soon.</p>
      </div>
    </div>
  </section>

  <ContactCTA />
</BaseLayout>
