---
import BaseLayout from '@layouts/BaseLayout.astro';
import TechStack from '@components/TechStack.astro';
import SocialLinks from '@components/SocialLinks.astro';
import Timeline from '@components/Timeline.astro';
import ValueCards from '@components/ValueCards.astro';

const technologies = [
  // Mobile
  { name: 'React Native', category: 'mobile' as const },
  { name: 'Expo', category: 'mobile' as const },
  { name: 'TypeScript', category: 'mobile' as const },
  { name: 'JavaScript', category: 'mobile' as const },
  { name: 'iOS', category: 'mobile' as const },
  { name: 'Android', category: 'mobile' as const },
  { name: 'Swift', category: 'mobile' as const },
  { name: 'Kotlin', category: 'mobile' as const },
  { name: 'Objective-C', category: 'mobile' as const },
  { name: 'Java', category: 'mobile' as const },
  // Frontend
  { name: 'React', category: 'frontend' as const },
  { name: 'TypeScript', category: 'frontend' as const },
  { name: 'JavaScript', category: 'frontend' as const },
  { name: 'Next.js', category: 'frontend' as const },
  { name: 'Tailwind CSS', category: 'frontend' as const },
  { name: 'Astro', category: 'frontend' as const },
  // Backend
  { name: 'Node.js', category: 'backend' as const },
  { name: 'PostgreSQL', category: 'backend' as const },
  { name: 'REST APIs', category: 'backend' as const },
  { name: 'GraphQL', category: 'backend' as const },
  // Tools
  { name: 'Git', category: 'tools' as const },
  { name: 'GitHub', category: 'tools' as const },
  { name: 'VS Code', category: 'tools' as const },
  { name: 'Cursor', category: 'tools' as const },
  { name: 'Figma', category: 'tools' as const },
  { name: 'Jira', category: 'tools' as const },
  { name: 'Expo OTA Updates', category: 'tools' as const },
  // AI & Automation
  { name: 'ChatGPT', category: 'ai & automation' as const },
  { name: 'Claude', category: 'ai & automation' as const },
  { name: 'GitHub Copilot', category: 'ai & automation' as const },
  { name: 'n8n', category: 'ai & automation' as const },
  { name: 'Make', category: 'ai & automation' as const },
  { name: 'Zapier', category: 'ai & automation' as const },
];
---

<BaseLayout
  title="About"
  description="Learn more about Derek Jensen — a 20-year software industry veteran teaching non-technical people to build real things with AI."
>
  <!-- Page Header -->
  <section class="py-12 sm:py-16">
    <div class="animate-in">
      <h1
        class="text-4xl sm:text-5xl font-bold text-neutral-900 mb-6 tracking-tight"
      >
        About Me
      </h1>
      <p class="text-xl text-neutral-600 max-w-2xl leading-relaxed">
        I've spent over 20 years in the software industry building mobile applications,
        web products, and everything in between. Now I'm focused on something different:
        using that experience to help non-technical people build real software with AI —
        without needing to become an engineer to do it.
      </p>
    </div>
  </section>

  <!-- Timeline Preview -->
  <section class="py-16 border-t border-neutral-200">
    <div class="animate-in delay-1">
      <h2
        class="text-sm font-medium text-neutral-500 uppercase tracking-wider mb-12 text-center"
      >
        Recent Journey
      </h2>
      <Timeline
        preview={true}
        previewCount={2}
        moreLink="/about/timeline"
        moreLinkText="View Full Timeline"
      />
    </div>
  </section>

  <!-- Current Focus & Tech Stack -->
  <section class="py-12 border-t border-neutral-200">
    <div class="animate-in delay-2">
      <h2
        class="text-sm font-medium text-neutral-500 uppercase tracking-wider mb-6"
      >
        Current Focus
      </h2>
      <div class="grid md:grid-cols-2 gap-8">
        <div>
          <p class="text-neutral-700 leading-relaxed mb-4">
            Right now my energy is split between two things: writing practical guides
            that help non-technical people build with AI, and building in public to show
            what's actually possible. The <a
              href="/blog"
              class="text-primary-600 hover:text-primary-700 font-medium"
              >blog</a
            > is the core of it — real-world walkthroughs of AI tools, workflows, and
            the mental models that matter most when you're building without a traditional
            engineering background.
          </p>
          <p class="text-neutral-700 leading-relaxed">
            I'm also documenting everything I build in real time through the <a
              href="/projects/curb-appeal"
              class="text-primary-600 hover:text-primary-700 font-medium"
              >Curb Appeal</a
            > series — an ongoing project using AI to generate website redesigns for real
            local businesses. It's the kind of applied, practical AI work I write about,
            done publicly so you can follow along and learn from both the wins and the
            stumbles.
          </p>
        </div>
        <div class="card p-6">
          <h3 class="text-sm font-medium text-neutral-900 mb-4">
            Technologies I Work With
          </h3>
          <TechStack technologies={technologies} showCategories={true} />
        </div>
      </div>
    </div>
  </section>

  <!-- Value Proposition -->
  <section class="py-12 border-t border-neutral-200">
    <div class="animate-in delay-3">
      <h2
        class="text-sm font-medium text-neutral-500 uppercase tracking-wider mb-6"
      >
        What I Bring to the Table
      </h2>
      <ValueCards />
    </div>
  </section>

  <!-- Personal Touches -->
  <section class="py-12 border-t border-neutral-200">
    <div class="animate-in delay-3">
      <h2
        class="text-sm font-medium text-neutral-500 uppercase tracking-wider mb-6"
      >
        Beyond the Code
      </h2>
      <div class="prose max-w-none">
        <p class="text-neutral-700 leading-relaxed mb-4">
          When I'm not writing or building, you'll probably find me at a local
          taproom. I'm a firm believer that the best ideas come when you step
          away from the screen — and some of my best post ideas have started on
          a barstool.
        </p>
        <p class="text-neutral-700 leading-relaxed mb-4">
          I care a lot about making technology accessible. Twenty years in this
          industry taught me that the gap between "technical" and "non-technical"
          is mostly a myth — it's really just a gap in exposure and tooling. AI
          is closing that gap fast, and I want to help people on the other side
          of it move quicker.
        </p>
        <p class="text-neutral-700 leading-relaxed">
          The <a
            href="/blog"
            class="text-primary-600 hover:text-primary-700 font-medium">blog</a
          > is where most of that thinking lives — practical guides on building
          with AI, lessons from real projects, and honest takes on what works
          and what doesn't.
        </p>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-12 border-t border-neutral-200">
    <div class="animate-in delay-4">
      <div
        class="p-8 rounded-lg"
        style="background-color: oklch(20% 0.008 260);"
      >
        <div
          class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6"
        >
          <div>
            <h2 class="text-xl font-semibold text-white mb-2">
              Let's Work Together
            </h2>
            <p class="text-neutral-300" style="color: oklch(86% 0.008 260);">
              Interested in collaborating or have a project in mind? I'd love to
              hear from you.
            </p>
          </div>
          <div class="flex flex-wrap gap-3">
            <a
              href="/contact"
              class="btn bg-white text-neutral-900 hover:bg-neutral-50"
            >
              Contact Me
            </a>
            <a
              href="/projects"
              class="btn border-2 border-white text-white hover:bg-white hover:text-neutral-900"
            >
              View My Work
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
