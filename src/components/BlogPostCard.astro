---
interface Props {
  title: string;
  description: string;
  href: string;
  pubDate?: Date;
  readingTime?: string;
  heroImage?: string;
  featured?: boolean;
  compact?: boolean;
}

const { title, description, href, pubDate, readingTime, heroImage, featured = false, compact = false } = Astro.props;

const formatDate = (date: Date) => {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });
};
---

{featured ? (
  <article class="group">
    <a href={href} class="block">
      {heroImage ? (
        <div class="grid sm:grid-cols-2 gap-6 items-center">
          <div class="rounded-xl overflow-hidden bg-neutral-100 aspect-video">
            <img
              src={heroImage}
              alt={title}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
            />
          </div>
          <div>
            <h3 class="text-2xl font-bold text-neutral-900 group-hover:text-primary-600 transition-colors duration-200 leading-snug mb-3">
              {title}
            </h3>
            <p class="text-neutral-600 leading-relaxed line-clamp-3 mb-4">
              {description}
            </p>
            <div class="flex items-center gap-3 text-sm text-neutral-500">
              {pubDate && (
                <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
              )}
              {readingTime && (
                <>
                  <span>·</span>
                  <span>{readingTime}</span>
                </>
              )}
            </div>
          </div>
        </div>
      ) : (
        <div>
          <h3 class="text-2xl font-bold text-neutral-900 group-hover:text-primary-600 transition-colors duration-200 leading-snug mb-3">
            {title}
          </h3>
          <p class="text-neutral-600 leading-relaxed line-clamp-3 mb-4">
            {description}
          </p>
          <div class="flex items-center gap-3 text-sm text-neutral-500">
            {pubDate && (
              <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
            )}
            {readingTime && (
              <>
                <span>·</span>
                <span>{readingTime}</span>
              </>
            )}
          </div>
        </div>
      )}
    </a>
  </article>
) : (
  <article class="group">
    <a href={href} class="block h-full">
      {heroImage && (
        <div class:list={["rounded-xl overflow-hidden bg-neutral-100 mb-3", compact ? "aspect-video" : "aspect-video mb-4"]}>
          <img
            src={heroImage}
            alt={title}
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
          />
        </div>
      )}
      <h3 class:list={["font-semibold text-neutral-900 group-hover:text-primary-600 transition-colors duration-200 leading-snug mb-1", compact ? "text-sm" : ""]}>
        {title}
      </h3>
      {!compact && (
        <p class="text-neutral-600 text-sm leading-relaxed line-clamp-2 mb-3">
          {description}
        </p>
      )}
      <div class="flex items-center gap-2 text-xs text-neutral-500 mt-2">
        {pubDate && (
          <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
        )}
        {readingTime && (
          <>
            <span>·</span>
            <span>{readingTime}</span>
          </>
        )}
      </div>
    </a>
  </article>
)}

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
