---
interface Props {
  title: string;
  description: string;
  href: string;
  pubDate?: Date;
  readingTime?: string;
  heroImage?: string;
  featured?: boolean;
}

const { title, description, href, pubDate, readingTime, heroImage, featured = false } = Astro.props;

const formatDate = (date: Date) => {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });
};
---

{featured ? (
  <article class="group">
    <a href={href} class="block">
      <div class="grid sm:grid-cols-2 gap-6 items-center">
        <div class="rounded-xl overflow-hidden bg-neutral-100 aspect-video">
          {heroImage ? (
            <img
              src={heroImage}
              alt={title}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
            />
          ) : (
            <div class="w-full h-full bg-gradient-to-br from-primary-100 to-primary-200" />
          )}
        </div>
        <div>
          <h3 class="text-2xl font-bold text-neutral-900 group-hover:text-primary-600 transition-colors duration-200 leading-snug mb-3">
            {title}
          </h3>
          <p class="text-neutral-600 leading-relaxed line-clamp-3 mb-4">
            {description}
          </p>
          <div class="flex items-center gap-3 text-sm text-neutral-500">
            {pubDate && (
              <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
            )}
            {readingTime && (
              <>
                <span>·</span>
                <span>{readingTime}</span>
              </>
            )}
          </div>
        </div>
      </div>
    </a>
  </article>
) : (
  <article class="group">
    <a href={href} class="block h-full">
      <div class="rounded-xl overflow-hidden bg-neutral-100 aspect-video mb-4">
        {heroImage ? (
          <img
            src={heroImage}
            alt={title}
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
          />
        ) : (
          <div class="w-full h-full bg-gradient-to-br from-primary-100 to-primary-200" />
        )}
      </div>
      <h3 class="font-semibold text-neutral-900 group-hover:text-primary-600 transition-colors duration-200 leading-snug mb-2">
        {title}
      </h3>
      <p class="text-neutral-600 text-sm leading-relaxed line-clamp-2 mb-3">
        {description}
      </p>
      <div class="flex items-center gap-2 text-xs text-neutral-500">
        {pubDate && (
          <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
        )}
        {readingTime && (
          <>
            <span>·</span>
            <span>{readingTime}</span>
          </>
        )}
      </div>
    </a>
  </article>
)}

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
